/*
 * QSPI Flash Test - MX25R1635F
 * REVITA_LINK pins:
 * CS: P0.26, CLK: P0.03
 * DIO0: P0.30, DIO1: P0.29, DIO2: P0.28, DIO3: P0.02
 * UART2: TX=P0.16, RX=P0.15
 */

&pinctrl {
    /* Override UART for debug output */
    uart0_default: uart0_default {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 16)>;
        };
        group2 {
            psels = <NRF_PSEL(UART_RX, 0, 15)>;
            bias-pull-up;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 16)>,
                    <NRF_PSEL(UART_RX, 0, 15)>;
            low-power-enable;
        };
    };

    /* Override QSPI pins for REVITA_LINK board */
    qspi_default: qspi_default {
        group1 {
            psels = <NRF_PSEL(QSPI_SCK, 0, 3)>,
                    <NRF_PSEL(QSPI_IO0, 0, 30)>,
                    <NRF_PSEL(QSPI_IO1, 0, 29)>,
                    <NRF_PSEL(QSPI_IO2, 0, 28)>,
                    <NRF_PSEL(QSPI_IO3, 0, 2)>,
                    <NRF_PSEL(QSPI_CSN, 0, 26)>;
            nordic,drive-mode = <NRF_DRIVE_H0H1>;
        };
    };

    qspi_sleep: qspi_sleep {
        group1 {
            psels = <NRF_PSEL(QSPI_SCK, 0, 3)>,
                    <NRF_PSEL(QSPI_IO0, 0, 30)>,
                    <NRF_PSEL(QSPI_IO1, 0, 29)>,
                    <NRF_PSEL(QSPI_IO2, 0, 28)>,
                    <NRF_PSEL(QSPI_IO3, 0, 2)>,
                    <NRF_PSEL(QSPI_CSN, 0, 26)>;
            low-power-enable;
        };
    };
};

&uart0 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

/* Override QSPI flash for MX25R1635F (16Mbit) */
&qspi {
    status = "okay";
    pinctrl-0 = <&qspi_default>;
    pinctrl-1 = <&qspi_sleep>;
    pinctrl-names = "default", "sleep";

    mx25r64: mx25r6435f@0 {
        compatible = "nordic,qspi-nor";
        reg = <0>;
        writeoc = "pp4io";
        readoc = "read4io";
        sck-frequency = <8000000>;
        jedec-id = [c2 28 15];  /* MX25R1635F */
        size = <16777216>;      /* 16Mbit = 2MB */
        has-dpd;
        t-enter-dpd = <10000>;
        t-exit-dpd = <35000>;
    };
};
