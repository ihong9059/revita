cmake:
  board:
    name: nrf52840dk
    path:
     - /home/uttec/ncs/zephyr/boards/nordic/nrf52840dk
    qualifiers: nrf52840
    revision: 
  images:
   - name: serial_counter
     source-dir: /home/uttec/revita/hwTest/serial_counter
     type: MAIN
  kconfig:
    files:
     - /home/uttec/revita/hwTest/serial_counter/build/_sysbuild/empty.conf
     - /home/uttec/revita/hwTest/serial_counter/build/_sysbuild/empty.conf
    user-files:
     - /home/uttec/revita/hwTest/serial_counter/build/_sysbuild/empty.conf
version: 0.1.0
west:
  command: /home/uttec/ncs/.venv/bin/west build -b nrf52840dk/nrf52840 /home/uttec/revita/hwTest/serial_counter -d /home/uttec/revita/hwTest/serial_counter/build --pristine
  topdir: /home/uttec/ncs
  version: 1.5.0
