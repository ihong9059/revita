#include <zephyr/kernel.h>
#include <zephyr/drivers/gpio.h>
#include <zephyr/console/console.h>
#include <string.h>

#define MAX_LINE_LEN 128

/* nRF52840 DK has 4 LEDs */
static const struct gpio_dt_spec leds[] = {
	GPIO_DT_SPEC_GET(DT_ALIAS(led0), gpios),
	GPIO_DT_SPEC_GET(DT_ALIAS(led1), gpios),
	GPIO_DT_SPEC_GET(DT_ALIAS(led2), gpios),
	GPIO_DT_SPEC_GET(DT_ALIAS(led3), gpios),
};

static char rx_buf[MAX_LINE_LEN];
static int rx_idx = 0;

int main(void)
{
	int ret;

	/* Initialize all LEDs */
	for (int i = 0; i < ARRAY_SIZE(leds); i++) {
		if (!gpio_is_ready_dt(&leds[i])) {
			return -1;
		}
		ret = gpio_pin_configure_dt(&leds[i], GPIO_OUTPUT_INACTIVE);
		if (ret < 0) {
			return -1;
		}
	}

	/* Initialize console for input */
	console_init();

	printk("UART Echo Test Started\n");
	printk("Type something and press Enter:\n");

	while (1) {
		int c = console_getchar();

		if (c == '\r' || c == '\n') {
			rx_buf[rx_idx] = '\0';
			if (rx_idx > 0) {
				printk("resend: %s\n", rx_buf);
				/* Toggle LED0 on each received line */
				gpio_pin_toggle_dt(&leds[0]);
			}
			rx_idx = 0;
		} else if (rx_idx < MAX_LINE_LEN - 1) {
			rx_buf[rx_idx++] = (char)c;
		}
	}

	return 0;
}
